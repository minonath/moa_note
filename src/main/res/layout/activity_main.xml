<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/meow">
    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="1sp"
            android:layout_marginBottom="1sp">
        <EditText
                android:id="@+id/top1"
                android:labelFor="@+id/top1"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:autofillHints=""
                android:inputType="text"
                android:layout_marginStart="1sp"
                android:layout_marginEnd="1sp"
                android:background="#FFFFFF"/>
        <TextView
                android:id="@+id/top2"
                android:textAlignment="center"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_marginStart="1sp"
                android:layout_marginEnd="1sp"
                android:background="#FFFFFF"/>
        <TextView
                android:id="@+id/top3"
                android:textAlignment="center"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_marginStart="1sp"
                android:layout_marginEnd="1sp"
                android:background="#FFFFFF"/>
    </LinearLayout>
    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginStart="1sp"
            android:layout_marginEnd="1sp"
            android:layout_marginTop="1sp"
            android:layout_marginBottom="1sp">
        <ImageView
                android:id="@+id/image"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitXY"
                tools:ignore="contentDescription"/>
    </LinearLayout>
    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="1sp"
            android:layout_marginBottom="1sp">
        <TextView
                android:id="@+id/middle1"
                android:textAlignment="center"
                android:layout_width="0sp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="1sp"
                android:layout_marginEnd="1sp"
                android:background="#FFFFFF"/>
        <TextView
                android:id="@+id/middle2"
                android:textAlignment="center"
                android:layout_width="0sp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="1sp"
                android:layout_marginEnd="1sp"
                android:background="#FFFFFF"/>
        <TextView
                android:id="@+id/middle3"
                android:textAlignment="center"
                android:layout_width="0sp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="1sp"
                android:layout_marginEnd="1sp"
                android:background="#FFFFFF"/>
        <TextView
                android:id="@+id/middle4"
                android:textAlignment="center"
                android:layout_width="0sp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="1sp"
                android:layout_marginEnd="1sp"
                android:background="#FFFFFF"/>
        <TextView
                android:id="@+id/middle5"
                android:textAlignment="center"
                android:layout_width="0sp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="1sp"
                android:layout_marginEnd="1sp"
                android:background="#FFFFFF"/>
        <TextView
                android:id="@+id/middle6"
                android:textAlignment="center"
                android:layout_width="0sp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="1sp"
                android:layout_marginEnd="1sp"
                android:background="#FFFFFF"/>
    </LinearLayout>
    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="1sp"
            android:layout_marginBottom="1sp">
        <TextView
                android:id="@+id/bottom1"
                android:textAlignment="center"
                android:layout_width="0sp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="1sp"
                android:layout_marginEnd="1sp"
                android:background="#FFFFFF"/>
        <TextView
                android:id="@+id/bottom2"
                android:textAlignment="center"
                android:layout_width="0sp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="1sp"
                android:layout_marginEnd="1sp"
                android:background="#FFFFFF"/>
        <TextView
                android:id="@+id/bottom3"
                android:textAlignment="center"
                android:layout_width="0sp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="1sp"
                android:layout_marginEnd="1sp"
                android:background="#FFFFFF"/>
        <TextView
                android:id="@+id/bottom4"
                android:textAlignment="center"
                android:layout_width="0sp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="1sp"
                android:layout_marginEnd="1sp"
                android:background="#FFFFFF"/>
        <TextView
                android:id="@+id/bottom5"
                android:textAlignment="center"
                android:layout_width="0sp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="1sp"
                android:layout_marginEnd="1sp"
                android:background="#FFFFFF"/>
        <TextView
                android:id="@+id/bottom6"
                android:textAlignment="center"
                android:layout_width="0sp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="1sp"
                android:layout_marginEnd="1sp"
                android:background="#FFFFFF"/>
    </LinearLayout>
</LinearLayout>